{
  "build": {
    "sourceDir": "templates",
    "outputDir": "dist",
    "cleanOutput": true
  },
  "targets": [
    {
      "id": "copilot",
      "name": "GitHub Copilot",
      "bundleName": "copilot.zip",
      "format": "markdown",
      "configDir": ".github",
      "directories": {
        "commands": ".github/prompts",
        "skills": ".github/skills",
        "guides": ".github/apm-guides",
        "agents": ".github/agents"
      },
      "subagentGuidance": {
        "hasSubagents": true,
        "toolSyntax": "#runSubagent with exploration focus",
        "explorerName": "exploration subagent",
        "configNote": null
      }
    },
    {
      "id": "claude",
      "name": "Claude Code",
      "bundleName": "claude.zip",
      "format": "markdown",
      "configDir": ".claude",
      "directories": {
        "commands": ".claude/commands",
        "skills": ".claude/skills",
        "guides": ".claude/apm-guides",
        "agents": ".claude/agents"
      },
      "subagentGuidance": {
        "hasSubagents": true,
        "toolSyntax": "Task(subagent_type=\"Explore\", prompt=\"...\")",
        "explorerName": "Explore",
        "configNote": null
      }
    },
    {
      "id": "gemini",
      "name": "Gemini CLI",
      "bundleName": "gemini.zip",
      "format": "toml",
      "configDir": ".gemini",
      "directories": {
        "commands": ".gemini/commands",
        "skills": ".gemini/skills",
        "guides": ".gemini/apm-guides",
        "agents": ".gemini/agents"
      },
      "subagentGuidance": {
        "hasSubagents": true,
        "toolSyntax": "codebase_investigator(query=\"...\")",
        "explorerName": "codebase_investigator",
        "configNote": "Requires `enableAgents: true` in ~/.gemini/settings.json"
      }
    },
    {
      "id": "cursor",
      "name": "Cursor",
      "bundleName": "cursor.zip",
      "format": "markdown",
      "configDir": ".cursor",
      "directories": {
        "commands": ".cursor/commands",
        "skills": ".cursor/skills",
        "guides": ".cursor/apm-guides",
        "agents": ".cursor/agents"
      },
      "subagentGuidance": {
        "hasSubagents": true,
        "toolSyntax": "Task(subagent_type=\"explore\", prompt=\"...\")",
        "explorerName": "explore",
        "configNote": null
      }
    },
    {
      "id": "opencode",
      "name": "OpenCode",
      "bundleName": "opencode.zip",
      "format": "markdown",
      "configDir": ".opencode",
      "directories": {
        "commands": ".opencode/command",
        "skills": ".opencode/skills",
        "guides": ".opencode/apm-guides",
        "agents": ".opencode/agents"
      },
      "subagentGuidance": {
        "hasSubagents": true,
        "toolSyntax": "task(subagent_type=\"explore\", prompt=\"...\")",
        "explorerName": "explore",
        "configNote": null
      }
    }
  ]
}
